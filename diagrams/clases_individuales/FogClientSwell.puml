@startuml FogClientSwell
!theme plain
skinparam linetype ortho

class FogClientSwell {
    - model: SwellMLP
    - server_address: str
    - region: str
    - partial_weights: dict
    + fit(parameters, config): Tuple
    + get_parameters(config): List
    + evaluate(parameters, config): Tuple
    - on_message(client, userdata, msg)
    - _wait_for_partial(): bool
}

@enduml
