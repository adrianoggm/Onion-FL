# ============================================================================
# Flower-Basic Environment Variables Template
# ============================================================================
# Copy this file to .env and customize the values for your environment.
# The .env file is ignored by git and will not be committed.
#
# Usage:
#   cp .env.template .env
#   # Edit .env with your values
#   docker compose -f docker-compose.otel.yml up -d
# ============================================================================

# -----------------------------------------------------------------------------
# MQTT Broker Configuration
# -----------------------------------------------------------------------------
MQTT_BROKER=localhost
MQTT_PORT=1883

# MQTT Topics
MQTT_TOPIC_GLOBAL=fl/global_model
MQTT_TOPIC_UPDATES=fl/updates
MQTT_TOPIC_PARTIAL=fl/partial

# -----------------------------------------------------------------------------
# Federated Learning Configuration
# -----------------------------------------------------------------------------
# Model input dimension (SWELL dataset default: 113)
INPUT_DIM=113

# Number of federated learning rounds
ROUNDS=3

# Minimum clients required for training
MIN_FIT_CLIENTS=2
MIN_AVAILABLE_CLIENTS=2

# Fog broker aggregation parameter (updates before partial aggregate)
FOG_K=2

# -----------------------------------------------------------------------------
# Data Paths
# -----------------------------------------------------------------------------
# Path to manifest file with federated splits
MANIFEST_PATH=/app/federated_runs/swell/example_manual/manifest.json

# Data directories for fog regions
FOG0_NODE_DIR=/app/federated_runs/swell/example_manual/fog_0
FOG1_NODE_DIR=/app/federated_runs/swell/example_manual/fog_1

# -----------------------------------------------------------------------------
# OpenTelemetry Configuration
# -----------------------------------------------------------------------------
# OTLP endpoint for sending traces (required for telemetry)
# - For local development: http://localhost:4318
# - Inside Docker: http://host.docker.internal:4318 or http://jaeger:4318
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# OTLP endpoint for metrics (optional, separate from traces)
# Only set this if you have a metrics-capable backend (e.g., OTEL Collector with Prometheus)
# If not set, metrics are disabled to avoid 404 errors with Jaeger-only setups
# OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=http://localhost:4320

# -----------------------------------------------------------------------------
# Grafana Configuration
# -----------------------------------------------------------------------------
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# -----------------------------------------------------------------------------
# Docker Network Configuration
# -----------------------------------------------------------------------------
# Network name for Docker services
DOCKER_NETWORK=flower-otel-network
