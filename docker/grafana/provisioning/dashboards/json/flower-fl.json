{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "grafana", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Federated Learning Metrics Dashboard",
  "editable": true,
  "liveNow": true,
  "panels": [
    {
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 100,
      "title": "Server Metrics",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]},
          "unit": "short"
        }
      },
      "gridPos": {"h": 5, "w": 4, "x": 0, "y": 1},
      "id": 1,
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"expr": "flower_fl_rounds_total", "legendFormat": "Rounds"}],
      "title": "FL Rounds",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]},
          "unit": "short"
        }
      },
      "gridPos": {"h": 5, "w": 4, "x": 4, "y": 1},
      "id": 2,
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"expr": "flower_fl_aggregations_total", "legendFormat": "Aggregations"}],
      "title": "Aggregations",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "continuous-GrYlRd"},
          "max": 1, "min": 0,
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 0.7}]},
          "unit": "percentunit"
        }
      },
      "gridPos": {"h": 5, "w": 6, "x": 8, "y": 1},
      "id": 3,
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"expr": "flower_fl_global_accuracy", "legendFormat": "Accuracy"}],
      "title": "Global Accuracy",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "continuous-RdYlGr"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]},
          "unit": "short"
        }
      },
      "gridPos": {"h": 5, "w": 6, "x": 14, "y": 1},
      "id": 4,
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"expr": "flower_fl_global_loss", "legendFormat": "Loss"}],
      "title": "Global Loss",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]},
          "unit": "short"
        }
      },
      "gridPos": {"h": 5, "w": 4, "x": 20, "y": 1},
      "id": 5,
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"expr": "flower_fl_active_clients", "legendFormat": "Clients"}],
      "title": "Active Clients",
      "type": "stat"
    },
    {
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 6},
      "id": 101,
      "title": "Client Metrics",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 20, "lineWidth": 2},
          "unit": "short"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 7},
      "id": 6,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "targets": [{"expr": "rate(flower_fl_client_training_rounds_total[1m])", "legendFormat": "{{region}}"}],
      "title": "Client Training Rate",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 20, "lineWidth": 2},
          "unit": "s"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 7},
      "id": 7,
      "options": {"legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"}},
      "targets": [{"expr": "histogram_quantile(0.95, rate(flower_fl_client_training_duration_seconds_bucket[5m]))", "legendFormat": "p95"}],
      "title": "Training Duration (p95)",
      "type": "timeseries"
    },
    {
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 15},
      "id": 102,
      "title": "Broker & Bridge Metrics",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "blue", "value": null}]}, "unit": "short"}},
      "gridPos": {"h": 5, "w": 4, "x": 0, "y": 16},
      "id": 8,
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"expr": "flower_fl_broker_updates_received_total", "legendFormat": "Updates"}],
      "title": "Broker: Updates",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "purple", "value": null}]}, "unit": "short"}},
      "gridPos": {"h": 5, "w": 4, "x": 4, "y": 16},
      "id": 9,
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"expr": "flower_fl_broker_partials_published_total", "legendFormat": "Partials"}],
      "title": "Broker: Partials",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "orange", "value": null}]}, "unit": "short"}},
      "gridPos": {"h": 5, "w": 4, "x": 8, "y": 16},
      "id": 10,
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"expr": "flower_fl_bridge_partials_received_total", "legendFormat": "Received"}],
      "title": "Bridge: Received",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": null}]}, "unit": "short"}},
      "gridPos": {"h": 5, "w": 4, "x": 12, "y": 16},
      "id": 11,
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"expr": "flower_fl_bridge_forwards_total", "legendFormat": "Forwards"}],
      "title": "Bridge: Forwards",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]}, "unit": "short"}},
      "gridPos": {"h": 5, "w": 4, "x": 16, "y": 16},
      "id": 12,
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"expr": "flower_fl_bridge_timeouts_total", "legendFormat": "Timeouts"}],
      "title": "Bridge: Timeouts",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "custom": {"drawStyle": "bars", "fillOpacity": 80}, "unit": "short"}},
      "gridPos": {"h": 5, "w": 4, "x": 20, "y": 16},
      "id": 13,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "targets": [{"expr": "flower_fl_broker_buffer_size", "legendFormat": "{{region}}"}],
      "title": "Buffer Size",
      "type": "timeseries"
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["flower", "federated-learning", "opentelemetry"],
  "time": {"from": "now-15m", "to": "now"},
  "title": "Flower Federated Learning",
  "uid": "flower-fl-dashboard",
  "version": 2
}
